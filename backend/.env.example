DATABASE_URL=file:./dev.db
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
PORT=5000
NODE_ENV=development
TWILIO_ACCOUNT_SID=YOUR_SID
SMTP_HOST=smtp.office365.com
SMTP_USER=YOUR_EMAIL
SMTP_PASS=YOUR_PASSWORD
FRONTEND_URL=http://localhost:5173

# Firebase Cloud Messaging (FCM)
# Option 1: Set service account JSON path via GOOGLE_APPLICATION_CREDENTIALS
# Option 2: Provide cert fields below
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
