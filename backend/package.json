{
  "name": "edumanage-backend",
  "version": "2.0.0",
  "description": "EduManage Pro - School ERP Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "cross-env PORT=5000 node src/server.js",
    "dev": "cross-env PORT=5000 nodemon --watch src --ext js,json --ignore prisma/*.db --ignore prisma/*.db-* src/server.js",
    "build": "npx prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node src/utils/seed.js",
    "db:backfill-links": "node src/utils/backfillPortalLinks.js",
    "smoke:api": "node scripts/api-smoke.js",
    "smoke:smtp": "node scripts/smtp-test.js"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^14.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.0"
  }
}
